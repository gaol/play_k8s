#!/bin/bash
# Health check for keepalived — verifies HAProxy is alive
# If HAProxy is down, keepalived lowers this node's priority
# so another master takes over the VIP.

errorExit() {
    echo "*** $*" 1>&2
    exit 1
}

curl --silent --max-time 2 --insecure https://localhost:8443/healthz -o /dev/null || errorExit "Error GET https://localhost:8443/healthz"
