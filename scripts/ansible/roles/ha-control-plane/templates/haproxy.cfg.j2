# K8s Load Balancer — API server + Ingress traffic
global
    log /dev/log local0
    maxconn 2000
    daemon

defaults
    log     global
    mode    tcp
    option  tcplog
    timeout connect 5s
    timeout client  30s
    timeout server  30s

# ---------------------------------------------------------------
# K8s API Server (masters)
# ---------------------------------------------------------------
frontend k8s_api
    bind *:6443
    default_backend k8s_api_backend

backend k8s_api_backend
    balance roundrobin
    option tcp-check
{% for master in masters %}
    server {{ master.name }} {{ master.ip }}:6443 check fall 3 rise 2
{% endfor %}

# ---------------------------------------------------------------
# Ingress HTTP — forwards to NGINX Ingress NodePort on workers
# ---------------------------------------------------------------
frontend ingress_http
    bind *:80
    default_backend ingress_http_backend

backend ingress_http_backend
    balance roundrobin
    option tcp-check
{% for worker in workers %}
    server {{ worker.name }} {{ worker.ip }}:{{ ingress_http_nodeport }} check fall 3 rise 2
{% endfor %}

# ---------------------------------------------------------------
# Ingress HTTPS — forwards to NGINX Ingress NodePort on workers
# ---------------------------------------------------------------
frontend ingress_https
    bind *:443
    default_backend ingress_https_backend

backend ingress_https_backend
    balance roundrobin
    option tcp-check
{% for worker in workers %}
    server {{ worker.name }} {{ worker.ip }}:{{ ingress_https_nodeport }} check fall 3 rise 2
{% endfor %}
