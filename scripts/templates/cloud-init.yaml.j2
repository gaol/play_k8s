#cloud-config
hostname: {{ node.name }}
fqdn: {{ node.name }}.{{ domain }}
manage_etc_hosts: false
timezone: "{{ node.timezone | default('UTC') }}"

# Grow the root partition to fill the cloned volume on first boot
growpart:
  mode: auto
  devices:
    - /
  ignore_growroot_disabled: false
resize_rootfs: true

package_update: false
{% if install_packages %}
packages:
{% for pkg in install_packages %}
  - {{ pkg }}
{% endfor %}
{% endif %}

users:
  - name: {{ ssh.username }}
    plain_text_passwd: {{ ssh.password }}
    ssh_authorized_keys:
      - {{ ssh.public_key }}
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: wheel
    shell: /bin/bash
    lock_passwd: false

ssh_pwauth: true

write_files:
  - path: /etc/modules-load.d/k8s-prereqs.conf
    content: |
      overlay
      br_netfilter

  - path: /etc/sysctl.d/99-k8s.conf
    content: |
      net.ipv4.ip_forward = 1
      net.bridge.bridge-nf-call-iptables = 1
      net.bridge.bridge-nf-call-ip6tables = 1

  # Static /etc/hosts with all cluster nodes (pre-DNS fallback)
  - path: /etc/hosts
    content: |
      127.0.0.1   localhost localhost.localdomain localhost4 localhost4.localdomain4
      ::1         localhost localhost.localdomain localhost6 localhost6.localdomain6
      {{ node.ip }}   {{ node.name }} {{ node.name }}.{{ domain }}
{% for n in all_nodes %}
{% if n.name != node.name %}
      {{ n.ip }}   {{ n.name }} {{ n.name }}.{{ domain }}
{% endif %}
{% endfor %}

{% set has_data_disk = (node.data_disk_size | default('0')) | int > 0 %}
{% if has_data_disk %}
disk_setup:
  /dev/vdb:
    table_type: gpt
    layout: true
    overwrite: true

fs_setup:
  - device: /dev/vdb1
    filesystem: ext4
    overwrite: true

mounts:
  - [/dev/vdb1, /mnt/data, ext4, "defaults,nofail", 0, 2]
{% endif %}

runcmd:
  - modprobe overlay
  - modprobe br_netfilter
  - sysctl --system
  - swapoff -a
  - sed -i.bak '/[[:space:]]swap[[:space:]]/s/^/#/' /etc/fstab
  - grubby --update-kernel=ALL --args="console=ttyS0,115200"
  - setenforce 0
  - sed -i 's/^SELINUX=enforcing/SELINUX=disabled/' /etc/selinux/config
{% if has_data_disk %}
  - mkdir -p /mnt/data
  - chown {{ ssh.username }}:{{ ssh.username }} /mnt/data
{% endif %}
{% for cmd in run_once_commands | default([]) %}
  - {{ cmd }}
{% endfor %}

power_state:
  mode: reboot
  message: "Rebooting after cloud-init setup"
  condition: true

---
# Network configuration (cloud-init network v2 / netplan format)
# This document is split from the one above by the provisioner and written
# as a separate network-config file in the cloud-init ISO.
version: 2
ethernets:
  {{ node.ifname | default("eth0") }}:
    dhcp4: false
    dhcp6: false
    addresses:
      - {{ node.ip }}/{{ subnet_prefix }}
    routes:
      - to: 0.0.0.0/0
        via: {{ node.gateway4 | default(gateway) }}
    nameservers:
      # libvirt bridge: dnsmasq resolves {{ domain }} and forwards external queries
      addresses:
        - {{ node.gateway4 | default(gateway) }}
      search:
        - {{ domain }}
